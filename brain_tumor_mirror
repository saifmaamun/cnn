ell_type":"code","source":"# 2. OPTIMIZED INPUT PIPELINE (DATA PARALLELISM HYPERPARAMETERS)\n# -------------------------------------------------------------------------\n# Scale batch size linearly with the number of processing units (GPUs)\nBASE_BATCH_SIZE = 32\nGLOBAL_BATCH_SIZE = BASE_BATCH_SIZE * NUM_REPLICAS\n\nIMAGE_SIZE = (224, 224)\nIMAGE_SHAPE = IMAGE_SIZE + (3,)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Define typical paths for Kaggle Brain Tumor Classification Dataset\n# Adjust paths if your specific dataset version labels directories differently\nTRAIN_DIR = '/kaggle/input/brain-tumor-classification-mri/Training'\nTEST_DIR = '/kaggle/input/brain-tumor-classification-mri/Testing'\n\nprint(f\"Targeting a Global Batch Size of {GLOBAL_BATCH_SIZE} split across devices.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Load training and validation pipelines cleanly with native TF components\ntrain_dataset = keras.utils.image_dataset_from_directory(\n    TRAIN_DIR,\n    validation_split=0.2,\n    subset=\"training\",\n    seed=42,\n    image_size=IMAGE_SIZE,\n    batch_size=GLOBAL_BATCH_SIZE,\n    label_mode='categorical'  # Generates 4-class one-hot vectors\n)\n\nval_dataset = keras.utils.image_dataset_from_directory(\n    TRAIN_DIR,\n    validation_split=0.2,\n    subset=\"validation\",\n    seed=42,\n    image_size=IMAGE_SIZE,\n    batch_size=GLOBAL_BATCH_SIZE,\n    label_mode='categorical'\n)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Crucial Step: Pre-fetching datasets into CPU cache memory while the GPUs process current batches.\n# This prevents your dual-GPU worker array from stalling out waiting for CPU disk read bottlenecks.\ntrain_dataset = train_dataset.prefetch(buffer_size=tf.data.AUTOTUNE)\nval_dataset = val_dataset.prefetch(buffer_size=tf.data.AUTOTUNE)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# 3. COMPILING THE HARDWARE-FUSED MODEL ARCHITECTURE\n# -------------------------------------------------------------------------\n# We declare and build the model inside the MirroredStrategy context scope.\n# This explicitly mirrors identical parameters to both T4 architectures.\nwith strategy.scope():\n    \n    # Instantiate native cuDNN-optimized DenseNet-121 application.\n    # This folds convolution, batch normalization, and activation steps into unified kernel \n    # instructions, eliminating register spill errors (ptxas warnings).\n    base_model = tf.keras.applications.DenseNet121(\n        weights='imagenet',  # Leverages pre-trained ImageNet weights for medical feature transfer\n        include_top=False,    # Discards default 1000-class head\n        input_shape=IMAGE_SHAPE\n    )\n    \n    # Allow backpropagation updates to fine-tune network weights across the dataset\n    base_model.trainable = True \n    \n    # Construct processing pipeline\n    inputs = layers.Input(shape=IMAGE_SHAPE, name=\"input_mri_images\")\n    \n    # Scale intensities between [0, 1] natively on-device\n    x = layers.Rescaling(1./255)(inputs)\n    x = base_model(x, training=True)\n    x = layers.GlobalAveragePooling2D(name=\"global_pooling\")(x)\n    x = layers.Dropout(0.3, name=\"regularization_dropout\")(x)\n    \n    # CRITICAL SECURITY RULE FOR MIXED PRECISION:\n    # Final dense activation layer MUST explicitly output float32 representation\n    # to avoid loss-scaling instabilities and floating point underflow during Softmax.\n    outputs = layers.Dense(4, activation='softmax', dtype='float32', name=\"output_classification\")(x)\n    \n    model = models.Model(inputs, outputs, name=\"Optimized_Dual_T4_DenseNet121\")\n    \n    # Compile the distributed architecture with a stable, standard learning rate\n    model.compile(\n        optimizer=keras.optimizers.Adam(learning_rate=1e-4),\n        loss='categorical_crossentropy',\n        metrics=['accuracy']\n    )","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Print a structured outline of the compiled framework\nmodel.summary()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Optional Performance Callbacks: Saving the highest performing weights \ncallbacks = [\n    keras.callbacks.EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True),\n    keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=3, verbose=1)\n]\n\nprint(\"\\nExecuting Training Lifecycle across Replicas...\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"EPOCHS = 30\n\nhistory = model.fit(\n    train_dataset,\n    validation_data=val_dataset,\n    epochs=EPOCHS,\n    callbacks=callbacks,\n    verbose=1\n)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# 5. DIAGNOSTIC PERFORMANCE ANALYSIS\n# -------------------------------------------------------------------------\n# Render execution trajectory\nacc = history.history['accuracy']\nval_acc = history.history['val_accuracy']\nloss = history.history['loss']\nval_loss = history.history['val_loss']\nepochs_range = range(len(acc))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"plt.figure(figsize=(14, 5))\nplt.subplot(1, 2, 1)\nplt.plot(epochs_range, acc, label='Training Accuracy')\nplt.plot(epochs_range, val_acc, label='Validation Accuracy')\nplt.legend(loc='lower right')\nplt.title('Training and Validation Accuracy Metrics')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"plt.subplot(1, 2, 2)\nplt.plot(epochs_range, loss, label='Training Loss')\nplt.plot(epochs_range, val_loss, label='Validation Loss')\nplt.legend(loc='upper right')\nplt.title('Training and Validation Loss Metrics')\npl